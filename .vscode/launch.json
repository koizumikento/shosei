{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "shosei: Extension Development Host",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode",
        "${workspaceFolder}"
      ]
    }
  ]
}
